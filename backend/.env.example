DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aifakeorreal
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS: web origins to allow (Chrome extension origins are matched by regex).
CORS_ORIGINS=["http://localhost:3000"]
CORS_ORIGIN_REGEX=chrome-extension://.*

# Score cache (Redis); set to 0 to disable.
CACHE_TTL_SECONDS=3600

# Rate limiting (per client IP, fixed window).
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
VOTE_RATE_LIMIT=30
ANALYZE_RATE_LIMIT=10
CHECK_RATE_LIMIT=120

# Fetch safety for /analyze.
MAX_URL_LENGTH=2048
MAX_FETCH_BYTES=2000000
BLOCK_PRIVATE_FETCH=true

# LLM fallback (ChatGPT): expensive, only for high-traffic uncertain content.
# Set LLM_FALLBACK_ENABLED=true and provide an OpenAI API key to activate.
LLM_FALLBACK_ENABLED=false
LLM_VISIT_THRESHOLD=50
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
