{
  "name": "aifakeorreal-extension",
  "version": "0.1.0",
  "description": "Crowdsourced AI content detection for any URL",
  "scripts": {
    "build": "webpack --mode production",
    "build:firefox": "TARGET=firefox webpack --mode production",
    "build:all": "npm run build && npm run build:firefox",
    "watch": "webpack --mode development --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist dist-firefox"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.277",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.6.3",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.7.2",
    "jsdom": "^25.0.1",
    "vitest": "^2.1.8",
    "webpack": "^5.97.1",
    "webpack-cli": "^6.0.1"
  }
}
